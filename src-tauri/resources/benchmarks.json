{
  "meta": {
    "description": "Chess benchmark statistics by rating bucket. Based on lichess database analysis methodology. Pentagon scores are normalized 0-100 where higher is always better.",
    "source": "lichess_database_estimates",
    "version": "1.0.0",
    "note": "Replace with real values after running the Rust parser against lichess database dump. Current values are research-based estimates.",
    "metrics": {
      "accuracy_avg": "Average game accuracy 0-100, lichess formula based on eval win probability delta",
      "accuracy_std": "Standard deviation of per-game accuracy — lower means more consistent",
      "acpl_avg": "Average centipawn loss per move",
      "acpl_std": "Standard deviation of ACPL",
      "blunders_per_game": "Average number of blunders (loss > 300cp) per game per side",
      "mistakes_per_game": "Average number of mistakes (loss 100-300cp) per game per side",
      "inaccuracies_per_game": "Average number of inaccuracies (loss 50-100cp) per game per side",
      "conversion_rate": "Fraction of games where player had eval >= +2.0 at some point AND won (0.0-1.0)",
      "endgame_blunder_rate": "Fraction of endgame moves that are blunders (loss > 200cp)",
      "opening_accuracy_avg": "Average accuracy during first 10 moves",
      "middlegame_accuracy_avg": "Average accuracy during moves 11-30",
      "endgame_accuracy_avg": "Average accuracy during moves 31+",
      "win_rate_as_white": "Win rate when playing white (0.0-1.0)",
      "win_rate_as_black": "Win rate when playing black (0.0-1.0)",
      "draw_rate": "Draw rate (0.0-1.0)",
      "games_analyzed": "Number of games used to compute this bucket (for confidence)",
      "pentagon": {
        "accuracy": "Normalized accuracy score 0-100 = accuracy_avg directly",
        "stability": "Normalized stability score 0-100 = max(0, 100 - accuracy_std * 4)",
        "conversion": "Normalized conversion score 0-100 = conversion_rate * 100",
        "openings": "Normalized opening score 0-100 = opening_accuracy_avg directly",
        "endgame": "Normalized endgame score 0-100 = (1 - endgame_blunder_rate) * 100"
      }
    }
  },
